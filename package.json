{
  "name": "@biomedica/qa",
  "private": true,
  "description": "QA orchestration - API (REST Assured), E2E (Playwright), gates, CI parity",
  "scripts": {
    "api": "mvn -f api/pom.xml -B verify",
    "e2e": "npm run test --prefix playwright",
    "e2e:fr": "npm run test:fr --prefix playwright",
    "smoke": "npm run test:smoke --prefix playwright",
    "smoke:fr": "npm run test:smoke:fr --prefix playwright",
    "e2e:ci": "npm run test:ci --prefix playwright",
    "typecheck:e2e": "npm run typecheck --prefix playwright",
    "gate": "node scripts/quality-gate.mjs",
    "ci:local": "node scripts/run-ci.mjs"
  }
}
