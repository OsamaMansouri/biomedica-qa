{
  "version": 2,
  "product": "Biomedica",
  "paths": {
    "playwrightDir": "playwright",
    "testCoverageCsv": "docs/spreadsheets/test-coverage.csv",
    "userStoriesDir": "US/stories"
  },
  "environments": {
    "local": {
      "playwrightOrigin": "http://localhost:3333",
      "apiBaseUrl": "http://localhost:8000",
      "testProductSlug": "argan-et-figue-de-barbarie"
    },
    "production": {
      "playwrightOrigin": "https://biomedica.ma",
      "apiBaseUrl": "https://api.biomedica.ma",
      "testProductSlug": "argan-et-figue-de-barbarie-60ml",
      "adminOrigin": "https://admin.biomedica.ma"
    }
  },
  "ciParity": {
    "order": ["typecheck", "smoke", "e2e"],
    "githubWorkflow": ".github/workflows/qa.yml",
    "scope": "QA repository only — not front/backend/admin",
    "defaultEnvironment": "production"
  },
  "playwright": {
    "smokeSpec": "code-first/smoke",
    "smokeTag": "@smoke",
    "projectsDefault": ["fr", "en"]
  }
}
