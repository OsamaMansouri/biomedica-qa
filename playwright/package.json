{
  "name": "biomedica-storefront-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E (Biomedica storefront) — code-first specs + BDD track.",
  "scripts": {
    "test": "playwright test code-first/e2e",
    "test:smoke": "playwright test code-first/smoke",
    "test:e2e": "playwright test code-first/e2e",
    "test:socket": "playwright test code-first/socket",
    "test:all": "playwright test code-first",
    "test:ci": "playwright test code-first/smoke code-first/e2e",
    "test:fr": "playwright test code-first/e2e --project=fr",
    "test:e2e:fr": "playwright test code-first/e2e --project=fr",
    "test:smoke:fr": "playwright test code-first/smoke --project=fr",
    "test:smoke:en": "playwright test code-first/smoke --project=en",
    "test:e2e:en": "playwright test code-first/e2e --project=en",
    "test:ci:fr": "playwright test code-first/smoke code-first/e2e --project=fr",
    "allure:generate": "allure generate reports/allure-results --output reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "report:allure": "allure generate reports/allure-results --output reports/allure-report --open",
    "clean:reports": "node --eval \"const fs=require('fs'); for (const p of ['reports','test-results','.features-gen','playwright-report-bdd']) fs.rmSync(p,{recursive:true,force:true}); for (const f of ['junit.xml','junit-bdd.xml']) fs.rmSync(f,{force:true});\"",
    "test:e2e:validation": "playwright test code-first/e2e --grep \"@validation\"",
    "test:e2e:cart": "playwright test code-first/e2e --grep \"@cart\"",
    "test:ui": "playwright test code-first/e2e --ui",
    "test:headed": "playwright test code-first/e2e --headed",
    "test:debug": "playwright test code-first/e2e --debug",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.13.9",
    "allure": "^3.9.0",
    "allure-playwright": "^3.9.0",
    "playwright-bdd": "^9.0.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
