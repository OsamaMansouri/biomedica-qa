{
  "name": "biomedica-playing-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E (Biomedica storefront) — même logique de dossiers que le projet QA sfcc.",
  "scripts": {
    "test": "playwright test tests/e2e",
    "test:smoke": "playwright test tests/smoke",
    "test:e2e": "playwright test tests/e2e",
    "test:socket": "playwright test tests/socket",
    "test:all": "playwright test",
    "test:ci": "playwright test tests/smoke tests/e2e --reporter=list,junit,html",
    "test:fr": "playwright test tests/e2e --project=fr",
    "test:smoke:fr": "playwright test tests/smoke --project=fr",
    "test:ci:fr": "playwright test tests/smoke tests/e2e --reporter=list,junit,html --project=fr",
    "test:ui": "playwright test tests/e2e --ui",
    "test:headed": "playwright test tests/e2e --headed",
    "test:debug": "playwright test tests/e2e --debug",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.13.9",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
