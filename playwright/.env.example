# Copy to .env (do not commit .env)
# Origine du site (sans locale) — utilisé pour les projets fr + en
PLAYWRIGHT_ORIGIN=http://localhost:3333

# Optionnel : si tu gardes une URL complète, l’origine est dérivée automatiquement
# PLAYWRIGHT_BASE_URL=http://localhost:3333/fr

# Optionnel : vérif santé API avant les tests (global-setup)
# PLAYWRIGHT_API_BASE_URL=http://localhost:8000

# Slug catalogue (défaut : argan-et-figue-de-barbarie ; prod biomedica.ma peut utiliser …-60ml)
PLAYWRIGHT_TEST_PRODUCT_SLUG=argan-et-figue-de-barbarie

# Magazine smoke (défauts = MagazinePostsSeeder)
# PLAYWRIGHT_TEST_MAGAZINE_ARTICLE_SLUG=choisir-gel-douche-selon-votre-peau
# PLAYWRIGHT_TEST_MAGAZINE_SECTION_SLUG=gel-douche-corps

# Optionnel : nombre de workers (défaut 3 partout si non défini). Baisse à 1 si la cible (ex. staging) sature en CI.
# PLAYWRIGHT_WORKERS=1
